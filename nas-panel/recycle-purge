#!/bin/bash
# Empty share recycle bins of anything older than 30 days.
# Run nightly by cron (cron-nas-maint).
PATH=/usr/bin:/bin
for r in /srv/nas/*/.recycle; do
	[ -d "$r" ] || continue
	find "$r" -type f -mtime +30 -delete 2>/dev/null
	find "$r" -depth -mindepth 1 -type d -empty -delete 2>/dev/null
done
