#!/bin/sh
### BEGIN INIT INFO
# Provides:          wsdd2
# Required-Start:    $network $remote_fs $syslog smbd nmbd
# Required-Stop:     $network $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: WSD/LLMNR discovery (makes CLIO visible to Windows)
# Description:       Serves WS-Discovery + LLMNR so modern Windows can
#                    find the box in Explorer > Network and resolve \\CLIO
#                    without NetBIOS/SMB1. Reads workgroup/netbios from
#                    /etc/samba/smb.conf. Foreground; supervised by
#                    start-stop-daemon --background.
### END INIT INFO

DAEMON=/usr/local/sbin/wsdd2
NAME=wsdd2
PIDFILE=/var/run/$NAME.pid
LOGFILE=/var/log/$NAME.log

[ -x "$DAEMON" ] || exit 0

start() {
    if [ -e "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME already running (pid $(cat $PIDFILE))"
        return 0
    fi
    echo -n "Starting $NAME: "
    start-stop-daemon --start --background --make-pidfile --pidfile "$PIDFILE" \
        --no-close --startas /bin/sh -- -c "exec $DAEMON >>$LOGFILE 2>&1"
    ret=$?
    [ $ret -eq 0 ] && echo "ok" || echo "FAILED ($ret)"
    return $ret
}

stop() {
    echo -n "Stopping $NAME: "
    start-stop-daemon --stop --quiet --retry=TERM/10/KILL/5 \
        --pidfile "$PIDFILE" --name "$NAME"
    ret=$?
    rm -f "$PIDFILE"
    [ $ret -eq 0 ] && echo "ok" || echo "not running"
    return $ret
}

status() {
    if [ -e "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "$NAME is running (pid $(cat $PIDFILE))"
        return 0
    fi
    echo "$NAME is not running"
    return 3
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart|force-reload) stop; sleep 1; start ;;
    status)  status ;;
    *) echo "Usage: $0 {start|stop|restart|force-reload|status}"; exit 2 ;;
esac
